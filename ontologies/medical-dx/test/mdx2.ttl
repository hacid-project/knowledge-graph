@prefix owlunit: <https://w3id.org/OWLunit/ontology/> .
@prefix test: <https://w3id.org/hacid/data/testcase/> .

test:mdx2.ttl a owlunit:CompetencyQuestionVerification ;
  owlunit:testsOntology <https://w3id.org/hacid/onto/mdx> ;
  owlunit:hasCompetencyQuestion "What are the diagnoses suggested by healthcare professionals?" ;
  owlunit:hasSPARQLUnitTest """
PREFIX top: <https://w3id.org/hacid/onto/top-level/>
PREFIX mdx: <https://w3id.org/hacid/onto/mdx/>

SELECT DISTINCT ?diagnosis ?disorderDescription ?disorder
WHERE {
  
 
  ?clinicalEval a mdx:ClinicalEvaluation ;
                mdx:forClinicalCase ?case ;
                mdx:hasDiagnosis ?diagnosis .

  ?case top:identifier ?caseId .
  FILTER(?caseId = "1883")
  
  ?disorderDescription mdx:isInScopeOfDiagnosis ?diagnosis ;
                       top:describes ?disorder .

} ORDER BY ?diagnosis ?disorderDescription ?disorder
""" ;

  owlunit:hasInputTestDataCategory owlunit:SPARQLEndpoint ;
  owlunit:hasInputData <https://semantics.istc.cnr.it/hacid/sparql> ;
