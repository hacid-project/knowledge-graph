@prefix owlunit: <https://w3id.org/OWLunit/ontology/> .
@prefix ex: <https://w3id.org/OWLunit/examples/> .
@prefix test: <https://w3id.org/hacid/data/testcase/> .

test:top12.ttl a owlunit:CompetencyQuestionVerification ;
  owlunit:testsOntology <https://w3id.org/hacid/onto/top-level> ;
  owlunit:hasCompetencyQuestion "What is next after a certain entity?" ;
  owlunit:hasSPARQLUnitTest """
PREFIX top: <https://w3id.org/hacid/onto/top-level/>
PREFIX test-data: <https://w3id.org/hacid/test-data/>

SELECT DISTINCT ?entityAfter
WHERE {
  test-data:entity2 top:precedes ?entityAfter .
} ORDER BY ?entityAfter
""" ;

  owlunit:hasInputTestDataCategory owlunit:ToyDataset ;
  owlunit:hasInputData <https://raw.githubusercontent.com/hacid-project/knowledge-graph/refs/heads/main/ontologies/top-level/test/top12-test-data.ttl> ;
  owlunit:hasExpectedResult """
{
  \"head\":{
    \"vars\":[
      \"entityAfter\"
    ]
  },
  \"results\":{
    \"bindings\":[
      {
        \"entityAfter\":{
          \"type\":\"uri\",
          \"value\":\"https://w3id.org/hacid/test-data/entity3a\"
        }
      },
      {
        \"entityAfter\":{
          \"type\":\"uri\",
          \"value\":\"https://w3id.org/hacid/test-data/entity3b\"
        }
      }
    ]
  }
}""" .
