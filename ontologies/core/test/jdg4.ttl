@prefix owlunit: <https://w3id.org/OWLunit/ontology/> .
@prefix ex: <https://w3id.org/OWLunit/examples/> .
@prefix test: <https://w3id.org/hacid/data/testcase/> .

test:jdg4.ttl a owlunit:CompetencyQuestionVerification ;
  owlunit:testsOntology <https://w3id.org/hacid/onto/core/judgement> ;
  owlunit:hasCompetencyQuestion "What is the judgement object of another judgement?" ;
  owlunit:hasSPARQLUnitTest """
PREFIX top: <https://w3id.org/hacid/onto/top-level/>
PREFIX jdg: <https://w3id.org/hacid/onto/core/judgement/>
PREFIX test-data: <https://w3id.org/hacid/test-data/>

SELECT DISTINCT ?judgement ?result ?metaResult
WHERE { 
  test-data:metajudgement a jdg:MetaJudgement ; 
                          jdg:judgesOn ?judgement ;
                          jdg:hasJudgmentResult ?metaResult .
  ?judgement a jdg:Judgement ; 
             jdg:hasJudgmentResult ?result . 
}
""" ;

  owlunit:hasInputTestDataCategory owlunit:ToyDataset ;
  owlunit:hasInputData <https://raw.githubusercontent.com/hacid-project/knowledge-graph/refs/heads/main/ontologies/core/test/jdg4-test-data.ttl> ;
  owlunit:hasExpectedResult """
{
  \"head\":{
    \"vars\":[
      \"judgement\",
      \"result\",
      \"metaResult\"
    ]
  },
  \"results\":{
    \"bindings\":[
      {
        \"judgement\":{
          \"type\":\"uri\",
          \"value\":\"https://w3id.org/hacid/test-data/judgement\"
        },
        \"result\":{
          \"type\":\"uri\",
          \"value\":\"https://w3id.org/hacid/test-data/pneumonia\"
        },
        \"metaResult\":{
          \"type\":\"uri\",
          \"value\":\"https://w3id.org/hacid/test-data/good-judgement\"
        }
      }
    ]
  }
}""" .
