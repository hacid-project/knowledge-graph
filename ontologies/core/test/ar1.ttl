@prefix owlunit: <https://w3id.org/OWLunit/ontology/> .
@prefix ex: <https://w3id.org/OWLunit/examples/> .
@prefix test: <https://w3id.org/hacid/data/testcase/> .

test:ar1.ttl a owlunit:CompetencyQuestionVerification ;
  owlunit:testsOntology <https://w3id.org/hacid/onto/core/agentrole> ;
  owlunit:hasCompetencyQuestion "What is the role played by a certain agent?" ;
  owlunit:hasSPARQLUnitTest """
PREFIX top: <https://w3id.org/hacid/onto/top-level/>
PREFIX ar: <https://w3id.org/hacid/onto/core/agentrole/>
PREFIX test-data: <https://w3id.org/hacid/test-data/>

SELECT DISTINCT ?role
WHERE {
  ?ar ar:involvesAgent test-data:John ;
      ar:involvesRole ?role .
} ORDER BY ?role
""" ;

  owlunit:hasInputTestDataCategory owlunit:ToyDataset ;
  owlunit:hasInputData <https://raw.githubusercontent.com/hacid-project/knowledge-graph/refs/heads/main/ontologies/core/test/ar1-test-data.ttl> ;
  owlunit:hasExpectedResult """
{
  \"head\":{
    \"vars\":[
      \"role\"
    ]
  },
  \"results\":{
    \"bindings\":[
      {
        \"role\":{
          \"type\":\"uri\",
          \"value\":\"https://w3id.org/hacid/test-data/cardiologist\"
        }
      }
    ]
  }
}""" .
