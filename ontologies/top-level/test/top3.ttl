@prefix owlunit: <https://w3id.org/OWLunit/ontology/> .
@prefix ex: <https://w3id.org/OWLunit/examples/> .
@prefix test: <https://w3id.org/hacid/data/testcase/> .

test:top3.ttl a owlunit:CompetencyQuestionVerification ;
  owlunit:testsOntology <https://w3id.org/hacid/onto/top-level> ;
  owlunit:hasCompetencyQuestion "Which agent does play a certain role?" ;
  owlunit:hasSPARQLUnitTest """
PREFIX top: <https://w3id.org/hacid/onto/top-level/>
PREFIX test-data: <https://w3id.org/hacid/test-data/>

SELECT DISTINCT ?agent
WHERE {
  test-data:role2 top:isRoleOf ?agent .
} ORDER BY ?agent
""" ;

  owlunit:hasInputTestDataCategory owlunit:ToyDataset ;
  owlunit:hasInputData <https://raw.githubusercontent.com/hacid-project/knowledge-graph/refs/heads/main/ontologies/top-level/test/top3-test-data.ttl> ;
  owlunit:hasExpectedResult """
{
  \"head\":{
    \"vars\":[
      \"agent\"
    ]
  },
  \"results\":{
    \"bindings\":[
      {
        \"agent\":{
          \"type\":\"uri\",
          \"value\":\"https://w3id.org/hacid/test-data/agent1\"
        }
      },
      {
        \"agent\":{
          \"type\":\"uri\",
          \"value\":\"https://w3id.org/hacid/test-data/agent2\"
        }
      }
    ]
  }
}""" .
