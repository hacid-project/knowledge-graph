@prefix owlunit: <https://w3id.org/OWLunit/ontology/> .
@prefix ex: <https://w3id.org/OWLunit/examples/> .
@prefix test: <https://w3id.org/hacid/data/testcase/> .

test:top4.ttl a owlunit:CompetencyQuestionVerification ;
  owlunit:testsOntology <https://w3id.org/hacid/onto/top-level> ;
  owlunit:hasCompetencyQuestion "What is the role played by a given agent?" ;
  owlunit:hasSPARQLUnitTest """
PREFIX top: <https://w3id.org/hacid/onto/top-level/>
PREFIX test-data: <https://w3id.org/hacid/test-data/>

SELECT DISTINCT ?role
WHERE {
  test-data:agent2 top:hasRole ?role.
} ORDER BY ?role
""" ;

  owlunit:hasInputTestDataCategory owlunit:ToyDataset ;
  owlunit:hasInputData <https://raw.githubusercontent.com/hacid-project/knowledge-graph/refs/heads/main/ontologies/top-level/test/top4-test-data.ttl> ;
  owlunit:hasExpectedResult """
{
  \"head\":{
    \"vars\":[
      \"role\"
    ]
  },
  \"results\":{
    \"bindings\":[
      {
        \"role\":{
          \"type\":\"uri\",
          \"value\":\"https://w3id.org/hacid/test-data/role2\"
        }
      },
      {
        \"role\":{
          \"type\":\"uri\",
          \"value\":\"https://w3id.org/hacid/test-data/role3\"
        }
      }
    ]
  }
}""" .
